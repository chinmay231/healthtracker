# ── Recovery Companion — config ──────────────────────────────────────────────
#
# Copy this file to .env and fill in your details.
#
# HOW TO GET YOUR CALLMEBOT API KEY (free, takes 2 minutes):
#   1. Save +34 644 51 68 88 in your contacts as "CallMeBot"
#   2. Send THIS exact WhatsApp message to that number:
#        I allow callmebot to send me messages
#   3. You will receive your API key in reply.
#   4. Paste it below.
#
# Your phone number must include the country code (no + sign, no spaces).
# Examples:  919876543210  (India)   447911123456  (UK)   12025551234  (US)
#
# These are the DEFAULT fallback settings for one WhatsApp number.
# Extra caretakers can now save their own phone + API key inside the app.

WHATSAPP_PHONE=919876543210
CALLMEBOT_APIKEY=YOUR_API_KEY_HERE

# Port the server runs on (default 8084)
PORT=8084
